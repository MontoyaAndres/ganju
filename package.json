{
  "name": "ganju",
  "version": "0.0.0",
  "main": "index.js",
  "repository": "git@github.com:MontoyaAndres/ganju.git",
  "author": "MontoyaAndres <andresmontoyafcb@gmail.com>",
  "packageManager": "npm@11.17.0",
  "license": "Apache-2.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "landing"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "start": "turbo run start",
    "clean": "turbo run clean && rm -r node_modules",
    "generate": "turbo run generate",
    "migrate-dev": "turbo run generate && turbo run migrate-dev",
    "migrate-prod": "turbo run generate && turbo run migrate-prod",
    "deploy-dev": "turbo run deploy-dev",
    "deploy-prod": "turbo run deploy-prod",
    "landing-preview": "npm run preview -w landing",
    "landing-deploy": "npm run deploy-prod -w landing"
  },
  "dependencies": {
    "turbo": "^2.9.18"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "wrangler": "^4.100.0"
  }
}
