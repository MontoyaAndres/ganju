---
import Base from './Base.astro';
import DocsSidebar from '../components/DocsSidebar.astro';
import DocsFeedback from '../components/DocsFeedback.astro';
import { normalizePath } from '../lib/docs-nav';

interface Props {
  title: string;
  description?: string;
  mdPath?: string;
}

const { title, description, mdPath } = Astro.props;
const current = normalizePath(Astro.url.pathname);
---

<Base {title} {description} {mdPath}>
  <section class="section docs-section">
    <div class="container docs-shell">
      <DocsSidebar {current} />
      <div class="docs-content">
        <slot />
      </div>
    </div>
  </section>
  <DocsFeedback />
</Base>
