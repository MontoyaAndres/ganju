---
import Base from '../layouts/Base.astro';
import { SITE, PRICING_SCHEMA, breadcrumbSchema, faqSchema } from '../lib/site';
import PricingCalculator from '../components/react/PricingCalculator.tsx';
import { PRICING } from '../lib/pricing';

const description = 'Ganju pricing — start free, scale when you are ready, or self-host for free under Apache-2.0.';

// Answers to what people actually type into search before they buy. Every one
// of these restates a fact already on this page — keep them in sync.
const faqs = [
  {
    q: 'Is there a free plan?',
    a: 'Yes. The Free plan is $0/mo: one workspace, up to 7 tools, 3 prompts, 1 channel, 30 MB of files, and 100 channel messages a month on our shared AI model.'
  },
  {
    q: 'How much does Ganju cost?',
    a: 'Pro is $20/mo plus usage. It includes 3,000 messages a month and 5 GB of searchable content. Past that it is $2 per 1,000 messages and $0.50 per GB — or connect your own AI model and keep going.'
  },
  {
    q: 'What is MCP?',
    a: "MCP (the Model Context Protocol) is the standard way AI assistants connect to outside tools and information. Ganju gives you an MCP server without any of the setup, so assistants like Claude, ChatGPT, and Cursor can use your files and tools. You don't need to understand the protocol to use it."
  },
  {
    q: 'Are MCP tool calls charged separately?',
    a: 'No. On Pro, MCP tool calls from clients like Claude, Cursor, and ChatGPT are bundled into the plan. Usage-based pricing applies to channel messages and searchable content, not to MCP tool calls.'
  },
  {
    q: 'Can I use my own AI model?',
    a: 'Yes. On Pro you can bring your own key for Anthropic Claude, OpenAI, or Google Gemini and run messages on your own model instead of ours.'
  },
  {
    q: 'Can I self-host Ganju for free?',
    a: 'Yes. Ganju is open source under Apache-2.0. Deploy it to your own account at no cost, and your data stays entirely in your account.'
  }
];

const jsonLd = [
  PRICING_SCHEMA,
  faqSchema(faqs),
  breadcrumbSchema([
    { label: 'Home', href: '/' },
    { label: 'Pricing', href: '/pricing' }
  ])
];
---

<Base title="Pricing" description={description} mdPath="/pricing.md" {jsonLd}>
  <section class="section">
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">Pricing</span>
        <h1>Start free. Scale when you're ready.</h1>
        <p>Use it free, upgrade as you grow — or run it yourself for free.</p>
      </div>

      <div class="pricing-grid">
        <article class="price-card reveal">
          <h3 class="tier">Free</h3>
          <div class="price"><span class="amount">$0</span><span class="per">/mo</span></div>
          <p class="tier-sub">Perfect for personal projects and trying things out.</p>
          <ul class="price-features">
            <li>1 workspace, no teammates</li>
            <li>Up to 7 tools, 3 prompts, 1 channel</li>
            <li>30&nbsp;MB files · ~5&nbsp;MB searchable content</li>
            <li>100 channel messages / mo on our shared AI model</li>
            <li>Your own connection link</li>
            <li>Community support</li>
          </ul>
          <a class="btn btn-ghost btn-block" href={SITE.appUrl} target="_blank" rel="noopener">Get started</a>
        </article>

        <article class="price-card price-featured reveal">
          <span class="ribbon">Most popular</span>
          <h3 class="tier">Pro</h3>
          <div class="price"><span class="amount">$20</span><span class="per">/mo + usage</span></div>
          <p class="tier-sub">For teams and growing products. Pay only for what you use beyond the base.</p>
          <ul class="price-features">
            <li>Unlimited projects, teammates, tools &amp; prompts</li>
            <li>Connect your own AI model (bring-your-own-key)</li>
            <li>Includes 3,000 messages/mo — run them on our AI model or your own — &amp; 5&nbsp;GB searchable content</li>
            <li>Past that, connect your own model to continue — then $2 / 1k messages · $0.50 / GB</li>
            <li>MCP tool calls bundled (Claude, Cursor, ChatGPT)</li>
            <li>Custom domain add-on · build your own tools</li>
            <li>24/7 support</li>
          </ul>
          <a class="btn btn-primary btn-block" href={SITE.appUrl} target="_blank" rel="noopener">Start Pro</a>
        </article>

        <article class="price-card reveal">
          <h3 class="tier">Enterprise</h3>
          <div class="price"><span class="amount">Custom</span></div>
          <p class="tier-sub">For larger organizations with advanced needs.</p>
          <ul class="price-features">
            <li>Everything in Pro</li>
            <li>Proxy your own / existing MCP server</li>
            <li>Custom web address &amp; tools</li>
            <li>SSO &amp; contract terms</li>
            <li>Dedicated support with guaranteed response times</li>
          </ul>
          <a class="btn btn-ghost btn-block" href="/contact">Contact sales</a>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container narrow">
      <div class="section-head reveal">
        <span class="eyebrow">Estimate your bill</span>
        <h2>What would Pro cost me?</h2>
        <p>Pick a starting point or move the sliders to match how you'll use Ganju. You only pay for two things: the messages your bots send and how much your AI can search.</p>
      </div>
      <PricingCalculator config={PRICING} client:visible />
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  <section class="section" id="faq">
    <div class="container narrow">
      <div class="section-head reveal">
        <span class="eyebrow">FAQ</span>
        <h2>Pricing questions</h2>
      </div>

      <div class="faq">
        {
          faqs.map((item) => (
            <details class="reveal">
              <summary>{item.q}</summary>
              <p>{item.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===== Still have questions? ===== -->
  <section class="section section-alt">
    <div class="container narrow">
      <div class="section-head reveal">
        <span class="eyebrow">Still deciding?</span>
        <h2>Not sure which plan fits?</h2>
        <p>Tell us what you're building and we'll help you pick — or set up a custom plan for bigger teams.</p>
      </div>
      <div class="hero-cta center reveal">
        <a class="btn btn-primary btn-lg" href="/contact">Contact us</a>
        <a class="btn btn-ghost btn-lg" href={SITE.appUrl} target="_blank" rel="noopener">Start free</a>
      </div>
    </div>
  </section>
</Base>
