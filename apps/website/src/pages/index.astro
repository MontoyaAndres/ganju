---
import Base from '../layouts/Base.astro';
import { SITE, SOFTWARE_APPLICATION_SCHEMA, faqSchema } from '../lib/site';

const faqs = [
  {
    q: 'Do I need to be technical to use Ganju?',
    a: 'No. If you can fill out a form and click a few buttons, you can set up Ganju — connecting your files, tools, and AI takes just a few minutes, no coding required. (Developers get powerful options too, like connecting their own apps.)'
  },
  {
    q: 'What is MCP?',
    a: "MCP (the Model Context Protocol) is the standard way AI assistants connect to outside tools and information. You don't need to understand the details — Ganju handles all of it so your AI can safely use your files and apps."
  },
  {
    q: 'Which AI assistants can I use?',
    a: 'Use Google Gemini, Anthropic Claude, or OpenAI (ChatGPT) — just add your own account. Other compatible providers work too.'
  },
  {
    q: 'Is my data safe?',
    a: "Yes. Your passwords and keys are encrypted, never shown in plain text, and never shared. Everything runs on Cloudflare's secure global network — and if you run Ganju yourself, your data stays entirely in your own account."
  },
  {
    q: 'Can I run Ganju myself?',
    a: 'Yes. Ganju is open source and free to use and modify. Host it on your own account, or let us run it for you on a paid plan.'
  }
];

const jsonLd = [SOFTWARE_APPLICATION_SCHEMA, faqSchema(faqs)];
---

<Base title={SITE.name} description={SITE.description} mdPath="/index.md" {jsonLd}>
  <!-- ===== Hero ===== -->
  <section class="hero">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="container hero-grid">
      <div class="hero-copy reveal">
        <a class="badge" href="/docs/deploy"><span class="dot"></span> Open source · Apache-2.0</a>
        <h1>Connect your AI to your files, tools &amp; apps.</h1>
        <p class="lead">
          Ganju lets AI assistants like Claude and ChatGPT — and your bots on Telegram, Slack,
          WhatsApp, and Discord — safely use your own documents, tools, and apps. Your AI answers
          with your information and gets real work done. Set it up in minutes, no coding required.
        </p>
        <div class="hero-cta">
          <a class="btn btn-primary btn-lg" href={SITE.appUrl} target="_blank" rel="noopener">
            Start building free
          </a>
          <a class="btn btn-ghost btn-lg" href="#how">See how it works</a>
        </div>
      </div>

      <div class="hero-art reveal">
        <div class="art-frame art-hero">
          <picture>
            <source srcset="/images/hero.webp" type="image/webp" />
            <img
              src="/images/hero.png"
              alt="Tools and AI clients connecting to your Ganju MCP server"
              width="1024"
              height="1024"
              fetchpriority="high"
              onerror="this.style.display = 'none'"
            />
          </picture>
        </div>
      </div>
    </div>

    <div class="container trustbar reveal">
      <span class="trust-label">Works with</span>
      <ul class="trust-logos">
        <li><a href="/docs/mcp"><img class="brand-ico" src="/icons/claude.svg" alt="Claude logo" loading="lazy" /> Claude</a></li>
        <li><a href="/docs/mcp"><img class="brand-ico" src="/icons/chatgpt.svg" alt="ChatGPT logo" loading="lazy" /> ChatGPT</a></li>
        <li><a href="/docs/mcp"><img class="brand-ico" src="/icons/cursor.svg" alt="Cursor logo" loading="lazy" /> Cursor</a></li>
        <li><a href="/docs/channels/telegram"><img class="brand-ico" src="/icons/telegram.svg" alt="Telegram logo" loading="lazy" /> Telegram</a></li>
        <li><a href="/docs/channels/slack"><img class="brand-ico" src="/icons/slack.svg" alt="Slack logo" loading="lazy" /> Slack</a></li>
        <li><a href="/docs/channels/whatsapp"><img class="brand-ico" src="/icons/whatsapp.svg" alt="WhatsApp logo" loading="lazy" /> WhatsApp</a></li>
        <li><a href="/docs/channels/discord"><img class="brand-ico" src="/icons/discord.svg" alt="Discord logo" loading="lazy" /> Discord</a></li>
      </ul>
    </div>
  </section>

  <!-- ===== Features ===== -->
  <section class="section" id="features">
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">Everything in one place</span>
        <h2>Everything your AI needs, in one place.</h2>
        <p>
          Add your documents, connect your tools, write instructions, and hook up your chat apps —
          all from one simple dashboard.
        </p>
      </div>

      <div class="feature-grid">
        <a class="card reveal" href="/docs/getting-started">
          <div class="art-spot">
            <picture>
              <source srcset="/images/feature-host.webp" type="image/webp" />
              <img src="/images/feature-host.png" alt="Managed hosting illustration" width="64" height="64" loading="lazy" onerror="this.style.display = 'none'" />
            </picture>
          </div>
          <h3>No setup, no servers</h3>
          <p>Nothing to install or maintain. Create a connection and it's live instantly — we host and run everything for you.</p>
        </a>

        <a class="card reveal" href="/docs/resources">
          <div class="art-spot">
            <picture>
              <source srcset="/images/feature-rag.webp" type="image/webp" />
              <img src="/images/feature-rag.png" alt="Search across your files illustration" width="64" height="64" loading="lazy" onerror="this.style.display = 'none'" />
            </picture>
          </div>
          <h3>Answers from your content</h3>
          <p>Upload files, add a website, or connect Google Drive or OneDrive. Your AI searches all of it and answers using your own information.</p>
        </a>

        <a class="card reveal" href="/docs/tools">
          <div class="art-spot">
            <picture>
              <source srcset="/images/feature-tools.webp" type="image/webp" />
              <img src="/images/feature-tools.png" alt="Pluggable tools illustration" width="64" height="64" loading="lazy" onerror="this.style.display = 'none'" />
            </picture>
          </div>
          <h3>Tools your AI can use</h3>
          <p>Let your AI handle email, check your calendar, search the web, post to Slack — or connect your own apps and services, no coding needed.</p>
        </a>

        <a class="card reveal" href="/docs/channels">
          <div class="art-spot">
            <picture>
              <source srcset="/images/feature-channels.webp" type="image/webp" />
              <img src="/images/feature-channels.png" alt="Messaging channels illustration" width="64" height="64" loading="lazy" onerror="this.style.display = 'none'" />
            </picture>
          </div>
          <h3>Bring it to your chat apps</h3>
          <p>Turn the same setup into a helpful bot on Telegram, Slack, WhatsApp, or Discord — for your team or your customers.</p>
        </a>

        <a class="card reveal" href="/docs/organizations-and-projects">
          <div class="art-spot">
            <picture>
              <source srcset="/images/feature-team.webp" type="image/webp" />
              <img src="/images/feature-team.png" alt="Team and shared projects illustration" width="64" height="64" loading="lazy" onerror="this.style.display = 'none'" />
            </picture>
          </div>
          <h3>Built for teams</h3>
          <p>Invite teammates, organize work into projects, and control who can do what — all built in from day one.</p>
        </a>

        <a class="card reveal" href="/docs/analytics">
          <div class="art-spot">
            <picture>
              <source srcset="/images/feature-audit.webp" type="image/webp" />
              <img src="/images/feature-audit.png" alt="Activity logs illustration" width="64" height="64" loading="lazy" onerror="this.style.display = 'none'" />
            </picture>
          </div>
          <h3>See everything it does</h3>
          <p>Every question, action, and message is recorded — so you always know what your AI did, when, and for whom.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== How it works ===== -->
  <section class="section section-alt" id="how">
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">From zero to connected</span>
        <h2>Up and running in four steps</h2>
        <p>No technical setup — just a few clicks.</p>
      </div>

      <div class="steps">
        <a class="step reveal" href="/docs/getting-started">
          <div class="art-frame art-step">
            <picture>
              <source srcset="/images/step-1.webp" type="image/webp" />
              <img src="/images/step-1.png" alt="Create a new Ganju workspace" width="1024" height="768" loading="lazy" onerror="this.style.display = 'none'" />
            </picture>
          </div>
          <div class="step-body">
            <span class="step-num">01</span>
            <h3>Create your workspace</h3>
            <p>Sign up and start a project — your private space to set everything up.</p>
          </div>
        </a>

        <a class="step reveal step-reverse" href="/docs/tools">
          <div class="art-frame art-step">
            <picture>
              <source srcset="/images/step-2.webp" type="image/webp" />
              <img src="/images/step-2.png" alt="Add documents and tools" width="1024" height="768" loading="lazy" onerror="this.style.display = 'none'" />
            </picture>
          </div>
          <div class="step-body">
            <span class="step-num">02</span>
            <h3>Add your content &amp; tools</h3>
            <p>Upload documents, connect a drive or website, and switch on the tools you want your AI to use.</p>
          </div>
        </a>

        <a class="step reveal" href="/docs/mcp">
          <div class="art-frame art-step">
            <picture>
              <source srcset="/images/step-3.webp" type="image/webp" />
              <img src="/images/step-3.png" alt="Securely connect an AI assistant" width="1024" height="768" loading="lazy" onerror="this.style.display = 'none'" />
            </picture>
          </div>
          <div class="step-body">
            <span class="step-num">03</span>
            <h3>Connect your AI</h3>
            <p>Link it to Claude, OpenAI, or Cursor in a couple of clicks. It stays private and secure.</p>
          </div>
        </a>

        <a class="step reveal step-reverse" href="/docs/channels">
          <div class="art-frame art-step">
            <picture>
              <source srcset="/images/step-4.webp" type="image/webp" />
              <img src="/images/step-4.png" alt="Share your assistant across chat apps" width="1024" height="768" loading="lazy" onerror="this.style.display = 'none'" />
            </picture>
          </div>
          <div class="step-body">
            <span class="step-num">04</span>
            <h3>Share it with your team</h3>
            <p>Add it as a bot on Telegram, Slack, WhatsApp, or Discord so anyone can use it.</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== Integrations ===== -->
  <section class="section" id="integrations">
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">Tools &amp; integrations</span>
        <h2>Connect the tools you already use.</h2>
        <p>Popular apps work right out of the box. Need something custom? Connect your own app or another service — without writing code.</p>
      </div>

      <div class="integration-grid reveal">
        <a class="chip" href="/docs/tools/gmail"><img class="brand-ico" src="/icons/gmail.svg" alt="Gmail logo" loading="lazy" /> Gmail</a>
        <a class="chip" href="/docs/tools/outlook"><img class="brand-ico" src="/icons/outlook.svg" alt="Outlook logo" loading="lazy" /> Outlook</a>
        <a class="chip" href="/docs/tools/slack"><img class="brand-ico" src="/icons/slack.svg" alt="Slack logo" loading="lazy" /> Slack</a>
        <a class="chip" href="/docs/tools/google-calendar"><img class="brand-ico" src="/icons/google-calendar.svg" alt="Google Calendar logo" loading="lazy" /> Google Calendar</a>
        <a class="chip" href="/docs/tools/calcom"><img class="brand-ico" src="/icons/calcom.svg" alt="Cal.com logo" loading="lazy" /> Cal.com</a>
        <a class="chip" href="/docs/tools/web-search">
          <svg class="brand-ico" aria-hidden="true" viewBox="0 0 24 24"><g fill="none" stroke="#0EA5A5" stroke-width="2.1" stroke-linecap="round"><circle cx="10.5" cy="10.5" r="5.3"></circle><path d="M14.6 14.6L20 20"></path></g></svg>
          Web Search
        </a>
        <a class="chip" href="/docs/resources"><img class="brand-ico" src="/icons/google-drive.svg" alt="Google Drive logo" loading="lazy" /> Google Drive</a>
        <a class="chip" href="/docs/resources"><img class="brand-ico" src="/icons/onedrive.svg" alt="OneDrive logo" loading="lazy" /> OneDrive</a>
        <a class="chip chip-accent" href="/docs/tools/http-endpoints">
          <svg class="brand-ico" aria-hidden="true" viewBox="0 0 24 24"><g fill="none" stroke="#1c1825" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 8l-4 4 4 4M15 8l4 4-4 4"></path></g></svg>
          http-endpoint
        </a>
        <a class="chip chip-accent" href="/docs/tools">
          <svg class="brand-ico" aria-hidden="true" viewBox="0 0 24 24"><g fill="none" stroke="#1c1825" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="5" cy="12" r="2"></circle><rect x="9.5" y="9.5" width="5" height="5" rx="1.2"></rect><circle cx="19" cy="12" r="2"></circle><path d="M7 12h2.5M14.5 12H17"></path></g></svg>
          mcp-proxy
        </a>
        <a class="chip" href="/docs/tools/notion"><img class="brand-ico" src="/icons/notion.svg" alt="Notion logo" loading="lazy" /> Notion</a>
        <a class="chip" href="/docs/tools/github"><img class="brand-ico" src="/icons/github.svg" alt="GitHub logo" loading="lazy" /> GitHub</a>
      </div>

      <div class="integration-note reveal">
        <strong>http-endpoint</strong> connects your own app or website.
        <strong>mcp-proxy</strong> plugs in other ready-made services like Notion and GitHub. Both work without writing any code.
      </div>
    </div>
  </section>

  <!-- ===== Pricing teaser ===== -->
  <section class="section section-alt" id="pricing">
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">Pricing</span>
        <h2>Start free. Scale when you're ready.</h2>
        <p>Use it free, upgrade as you grow — or run it yourself for free.</p>
      </div>
      <div class="hero-cta center reveal">
        <a class="btn btn-primary btn-lg" href="/pricing">See full pricing</a>
        <a class="btn btn-ghost btn-lg" href={SITE.appUrl} target="_blank" rel="noopener">Start free</a>
      </div>
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  <section class="section" id="faq">
    <div class="container narrow">
      <div class="section-head reveal">
        <span class="eyebrow">FAQ</span>
        <h2>Good questions</h2>
      </div>

      <div class="faq">
        {
          faqs.map((item) => (
            <details class="reveal">
              <summary>{item.q}</summary>
              <p>{item.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="cta" id="cta">
    <div class="cta-glow" aria-hidden="true"></div>
    <div class="container cta-inner reveal">
      <h2>Give your AI everything it needs to help.</h2>
      <p>Set it up in minutes — free to start.</p>
      <div class="hero-cta center">
        <a class="btn btn-primary btn-lg" href={SITE.appUrl} target="_blank" rel="noopener">Start building free</a>
        <a class="btn btn-ghost btn-lg" href="/docs">Read the docs</a>
      </div>
    </div>
  </section>
</Base>
