---
import { getCollection, render } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';

export async function getStaticPaths() {
  // `welcome` is served at /docs (the docs landing), so skip it here to avoid a
  // duplicate page at /docs/welcome.
  const docs = (await getCollection('docs')).filter((entry) => entry.id !== 'welcome');
  return docs.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<DocsLayout title={entry.data.title} description={entry.data.description} mdPath={`/docs/${entry.id}.md`}>
  <article class="prose docs-article">
    <p class="eyebrow">Documentation</p>
    <h1>{entry.data.title}</h1>
    <p class="lead">{entry.data.description}</p>
    <Content />
  </article>
</DocsLayout>
