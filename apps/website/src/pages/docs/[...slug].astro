---
import { getCollection, render } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';
import { docsTrail } from '../../lib/docs-nav';
import { SITE, breadcrumbSchema, techArticleSchema } from '../../lib/site';

export async function getStaticPaths() {
  // `welcome` is served at /docs (the docs landing), so skip it here to avoid a
  // duplicate page at /docs/welcome.
  const docs = (await getCollection('docs')).filter((entry) => entry.id !== 'welcome');
  return docs.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const path = `/docs/${entry.id}`;
const jsonLd = [
  techArticleSchema({
    title: entry.data.title,
    description: entry.data.description,
    url: new URL(path, SITE.url).href,
    updated: entry.data.updated
  }),
  breadcrumbSchema(docsTrail(path))
];
---

<DocsLayout
  title={entry.data.title}
  description={entry.data.description}
  mdPath={`/docs/${entry.id}.md`}
  {jsonLd}
>
  <article class="prose docs-article">
    <p class="eyebrow">Documentation</p>
    <h1>{entry.data.title}</h1>
    <p class="lead">{entry.data.description}</p>
    <Content />
    {
      entry.data.updated && (
        <p class="docs-updated">
          Last updated{' '}
          <time datetime={entry.data.updated.toISOString()}>
            {entry.data.updated.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric'
            })}
          </time>
        </p>
      )
    }
  </article>
</DocsLayout>
