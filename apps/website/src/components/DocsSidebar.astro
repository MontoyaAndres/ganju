---
import { DOCS_NAV } from '../lib/docs-nav';
import DocsNavNode from './DocsNavNode.astro';

interface Props {
  current: string;
}

const { current } = Astro.props;
---

<aside class="docs-aside">
  <button
    type="button"
    class="docs-menu-toggle"
    id="docsMenuToggle"
    aria-expanded="false"
    aria-controls="docsNav"
  >
    <svg class="docs-menu-icon" width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
      <path
        d="M4 6h16M4 12h16M4 18h16"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
      ></path>
    </svg>
    <span>Menu</span>
    <svg class="docs-menu-chevron" width="16" height="16" viewBox="0 0 24 24" aria-hidden="true">
      <path
        d="M8 10l4 4 4-4"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      ></path>
    </svg>
  </button>

  <nav class="docs-nav" id="docsNav" aria-label="Documentation">
    <p class="docs-nav-title">Documentation</p>
    <ul class="docs-navlist">
      {
        DOCS_NAV.map((node) => (
          <li>
            <DocsNavNode node={node} current={current} />
          </li>
        ))
      }
    </ul>
  </nav>
</aside>

<script>
  // Mobile: toggle the docs nav as a dropdown attached to the sticky "Menu" button.
  const toggle = document.getElementById('docsMenuToggle');
  const nav = document.getElementById('docsNav');
  if (toggle && nav) {
    const close = () => {
      nav.classList.remove('open');
      toggle.classList.remove('open');
      toggle.setAttribute('aria-expanded', 'false');
    };
    toggle.addEventListener('click', () => {
      const open = nav.classList.toggle('open');
      toggle.classList.toggle('open', open);
      toggle.setAttribute('aria-expanded', String(open));
    });
    // Close after choosing a destination.
    nav.querySelectorAll('a').forEach((a) => a.addEventListener('click', close));
    // Tapping outside the menu closes it.
    document.addEventListener('click', (e) => {
      if (!toggle.contains(e.target as Node) && !nav.contains(e.target as Node)) close();
    });
    // Reset when growing back to the desktop layout.
    window.addEventListener('resize', () => {
      if (window.innerWidth > 900) close();
    });
  }
</script>
