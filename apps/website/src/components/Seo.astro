---
import { SITE, ORGANIZATION_SCHEMA, WEBSITE_SCHEMA } from '../lib/site';
import Schema from './Schema.astro';

interface Props {
  title: string;
  description?: string;
  /** Path (e.g. `/docs/getting-started.md`) to the raw Markdown twin of this page. */
  mdPath?: string;
  ogType?: 'website' | 'article';
  image?: string;
  imageAlt?: string;
  /** Page-specific JSON-LD (FAQPage, SoftwareApplication, BlogPosting, …). */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  /** Set true to keep a page out of the index (e.g. thank-you pages). */
  noindex?: boolean;
  /** Brand half of the title tag. Docs override it to "Ganju Docs". */
  brand?: string;
}

const {
  title,
  description = SITE.description,
  mdPath,
  ogType = 'website',
  image = '/images/hero.png',
  imageAlt = SITE.tagline,
  jsonLd,
  noindex = false,
  brand = SITE.name
} = Astro.props;

const canonical = new URL(Astro.url.pathname, SITE.url).href;
const fullTitle = title === SITE.name ? SITE.homeTitle : `${title} — ${brand}`;
const imageUrl = new URL(image, SITE.url).href;
const mdUrl = mdPath ? new URL(mdPath, SITE.url).href : undefined;
const twitterHandle = '@' + SITE.social.x.split('/').pop();

// Global structured data (every page) plus any page-specific blocks.
const globalSchema = [ORGANIZATION_SCHEMA, WEBSITE_SCHEMA];
const pageSchema = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const schema = [...globalSchema, ...pageSchema];
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
<meta name="theme-color" content="#1C1825" />

<meta
  name="robots"
  content={noindex
    ? 'noindex, nofollow'
    : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'}
/>

{/* AI/agent-friendly: every page advertises its raw Markdown twin. */}
{mdUrl && <link rel="alternate" type="text/markdown" href={mdUrl} />}

<link
  rel="alternate"
  type="application/rss+xml"
  title={`${SITE.name} Blog`}
  href={new URL('/rss.xml', SITE.url).href}
/>

{/* Open Graph */}
<meta property="og:site_name" content={SITE.name} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:type" content={ogType} />
<meta property="og:url" content={canonical} />
<meta property="og:locale" content="en_US" />
<meta property="og:image" content={imageUrl} />
<meta property="og:image:alt" content={imageAlt} />
<meta property="og:image:width" content="2048" />
<meta property="og:image:height" content="2048" />

{/* Twitter */}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content={twitterHandle} />
<meta name="twitter:creator" content={twitterHandle} />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl} />
<meta name="twitter:image:alt" content={imageAlt} />

<Schema {schema} />
