---
import { SITE } from '../lib/site';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <a href="/" class="brand">
        <span class="brand-mark" aria-hidden="true"></span>
        <span class="brand-name">Ganju</span>
      </a>
      <p>Connect your AI to your files, tools, and apps.</p>

      <div class="footer-social">
        <a href={SITE.social.x} target="_blank" rel="noopener" aria-label="Ganju on X">
          <img class="brand-ico" src="/icons/x.svg" alt="X logo" loading="lazy" />
        </a>
        <a href={SITE.social.linkedin} target="_blank" rel="noopener" aria-label="Ganju on LinkedIn">
          <img class="brand-ico" src="/icons/linkedin.svg" alt="LinkedIn logo" loading="lazy" />
        </a>
        <a href={SITE.repo} target="_blank" rel="noopener" aria-label="Ganju on GitHub">
          <img class="brand-ico" src="/icons/github.svg" alt="GitHub logo" loading="lazy" />
        </a>
      </div>
    </div>

    <nav class="footer-col" aria-label="Product">
      <h4>Product</h4>
      <a href="/#features">Features</a>
      <a href="/#how">How it works</a>
      <a href="/#integrations">Integrations</a>
      <a href="/pricing">Pricing</a>
    </nav>

    <nav class="footer-col" aria-label="Resources">
      <h4>Resources</h4>
      <a href="/docs">Docs</a>
      <a href="/blog">Blog</a>
      <a href="/contact">Contact</a>
    </nav>

    <nav class="footer-col" aria-label="Legal">
      <h4>Legal</h4>
      <a href="/privacy">Privacy</a>
      <a href="/terms">Terms</a>
      <a href="https://www.apache.org/licenses/LICENSE-2.0" target="_blank" rel="noopener">
        License (Apache-2.0)
      </a>
    </nav>
  </div>
  <div class="container footer-bottom">
    <span>© {year} Ganju.</span>
  </div>
</footer>
