{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env"],
  "globalEnv": [
    "NODE_ENV",
    "RESOURCE_HANDLER_PORT",
    "DATABASE_URL",
    "JWT_SECRET",
    "CRYPTO_SECRET",
    "MCP_INTERNAL_SECRET",
    "BOT_OAUTH_CLIENT_ID",
    "BOT_OAUTH_CLIENT_SECRET",
    "EMBEDDING_API_KEY",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "GITHUB_CLIENT_ID",
    "GITHUB_CLIENT_SECRET",
    "MICROSOFT_CLIENT_ID",
    "MICROSOFT_CLIENT_SECRET",
    "SLACK_CLIENT_ID",
    "SLACK_CLIENT_SECRET",
    "STRIPE_SECRET_KEY",
    "STRIPE_WEBHOOK_SECRET",
    "STRIPE_PRICE_PRO",
    "STRIPE_PRICE_ENTERPRISE",
    "STRIPE_PRICE_MESSAGE_OVERAGE",
    "STRIPE_PRICE_EMBEDDED_OVERAGE",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_WEB_URL",
    "NEXT_PUBLIC_MCP_URL",
    "NEXT_PUBLIC_DOMAIN"
  ],
  "tasks": {
    "build": {
      "outputs": ["dist/**", ".next/**", "!.next/cache/**", "public/dist/**"],
      "dependsOn": ["^build"]
    },
    "test": {
      "outputs": ["coverage/**"],
      "dependsOn": []
    },
    "dev": {
      "inputs": [".env"],
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false
    },
    "clean": {
      "cache": false
    },
    "generate": {
      "cache": false
    },
    "migrate-dev": {
      "cache": false
    },
    "migrate-prod": {
      "cache": false
    },
    "deploy-dev": {
      "cache": false
    },
    "deploy-prod": {
      "cache": false
    }
  }
}